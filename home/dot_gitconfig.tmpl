# Managed by myplace (chezmoi). Identity is collected at install time
# (myplace bootstrap / chezmoi init) and stored in chezmoi's data — change it
# by re-running bootstrap with --git-email/--git-name, or editing the [data]
# block in ~/.config/chezmoi/chezmoi.toml. (dig falls back to the repo default.)
[user]
	name = {{ dig "gitName" "Mike Valstar" . }}
	email = {{ dig "gitEmail" "mike@valstar.dev" . }}

# delta — syntax-highlighting pager for git diffs. delta is in the mise tool
# baseline, so it's on every machine (servers included). git only pages to an
# interactive TTY, so agent/CI `git diff` output stays plain and unpolluted.
# https://dandavison.github.io/delta/
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true        # n / N jump between diff sections
	line-numbers = true
	syntax-theme = "Catppuccin Mocha"  # bundled in delta; matches bat/ghostty/starship/zed
[merge]
	conflictstyle = diff3  # show the base alongside both sides (delta renders it well)
[diff]
	colorMoved = default   # distinguish moved lines from added/removed
	algorithm = histogram  # better hunk matching than the default Myers
	mnemonicPrefix = true  # i/w/c/o prefixes instead of a/b in diff headers
	renames = true         # detect renames (and copies) in diffs

# Modern git defaults (ADR-0015). Non-destructive QoL knobs that every machine
# would otherwise set by hand — centralized here so the fleet behaves the same.
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true # first push of a new branch sets upstream automatically
	followTags = true      # push annotated tags reachable from pushed commits
[pull]
	rebase = true          # rebase local work on pull instead of a merge commit
[fetch]
	prune = true           # drop local refs for branches deleted on the remote
	pruneTags = true
[rebase]
	autoStash = true       # stash/unstash a dirty tree around a rebase
	updateRefs = true      # carry stacked branches along when rebasing
[rerere]
	enabled = true         # remember + replay conflict resolutions
[branch]
	sort = -committerdate  # `git branch` lists most-recently-used first
[tag]
	sort = -version:refname # `git tag` lists versions in semantic order
[column]
	ui = auto              # column output (branch/tag/status) when on a TTY
[commit]
	verbose = true         # show the diff in the commit-message editor
[help]
	autocorrect = prompt   # offer the intended command on a typo instead of running it

# SSH commit/tag signing (ADR-0015). Auto-enabled only when a signing key exists,
# so a keyless machine (most servers) silently skips signing rather than failing
# every commit. Key path defaults to ~/.ssh/id_ed25519.pub; override per machine
# with the `signingKey` chezmoi data key. The PUBLIC key must also be uploaded to
# GitHub as a *signing* key for the Verified badge — once per machine:
#   gh ssh-key add <key> --type signing --title "$(hostname)"
{{- $signingKey := dig "signingKey" (joinPath .chezmoi.homeDir ".ssh" "id_ed25519.pub") . }}
{{- if stat $signingKey }}
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = {{ joinPath .chezmoi.homeDir ".config" "git" "allowed_signers" | quote }}
[user]
	signingkey = {{ $signingKey | quote }}
[commit]
	gpgsign = true
[tag]
	gpgsign = true
{{- end }}
