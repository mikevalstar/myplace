# ~/.zshrc — managed by myplace (chezmoi). Edit in the repo
# (home/dot_zshrc), not here; local edits show as drift.
# Machine-local, non-shared tweaks belong in ~/.mvdotfiles.zsh.

# ---- oh-my-zsh ----
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
# Built-in omz plugins add completions/aliases for tools we use (gh, go,
# rustup, fnm) plus QoL (extract, Esc-Esc sudo, colored man pages). Keep
# zsh-syntax-highlighting LAST — it must load after everything else.
plugins=(git gh golang rust fnm extract sudo colored-man-pages zsh-autosuggestions zsh-syntax-highlighting)
[ -f "$ZSH/oh-my-zsh.sh" ] && source "$ZSH/oh-my-zsh.sh"

# ---- user configuration ----

# Real interactive terminal, or an agent/CI shell? Coding agents source this
# rc to capture PATH, but their prompt/history/cd-hook/keybinding chatter
# pollutes captured stdout (and zoxide's cd override can send them to the wrong
# dir). Gate interactive-only tooling on this; leave PATH/runtime setup ungated
# so agents still get mise/fnm/cargo. Env vars: CLAUDECODE+AI_AGENT (Claude
# Code), CURSOR_AGENT (Cursor), CODEX_SANDBOX (Codex), OPENCODE (opencode, not
# yet shipped — forward-compat). See docs/guides/agent-friendly-shell.md.
if [[ -o interactive && -z "$CLAUDECODE$AI_AGENT$CURSOR_AGENT$CODEX_SANDBOX$OPENCODE" ]]; then
  MYPLACE_INTERACTIVE_SHELL=1
else
  MYPLACE_INTERACTIVE_SHELL=0
fi
export MYPLACE_INTERACTIVE_SHELL

# Local bin first on PATH (myplace, fnm, rustup, and friends install here).
export PATH="$HOME/.local/bin:$PATH"

# myplace-managed helper scripts (chezmoi, see ADR-0014). Kept out of ~/.local/bin
# so they don't mingle with mise/installer binaries — run `mv_scripts` to list them.
[ -d "$HOME/.mvscripts" ] && export PATH="$HOME/.mvscripts:$PATH"

# mise — activate so mise-managed CLI tools are on PATH.
command -v mise >/dev/null 2>&1 && eval "$(mise activate zsh)"

# Personal shared dotfiles: tool inits, aliases, functions.
[ -f "$HOME/.mvdotfiles.zsh" ] && source "$HOME/.mvdotfiles.zsh"

# fnm (Node). Always put Node on PATH; only add the per-cd auto-switch hook
# for real terminals — under an agent/CI shell it prints "Using Node ..." on
# every cd, contaminating captured output. See docs/guides/agent-friendly-shell.md.
if command -v fnm >/dev/null 2>&1; then
  if [[ "$MYPLACE_INTERACTIVE_SHELL" == 1 ]]; then
    eval "$(fnm env --use-on-cd --shell zsh)"
  else
    eval "$(fnm env --shell zsh)"
  fi
fi

# Rust / cargo (rustup).
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# opencode
[ -d "$HOME/.opencode/bin" ] && export PATH="$HOME/.opencode/bin:$PATH"

# bun
export BUN_INSTALL="$HOME/.bun"
[ -d "$BUN_INSTALL/bin" ] && export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# Vite+ bin (https://viteplus.dev)
#[ -f "$HOME/.vite-plus/env" ] && . "$HOME/.vite-plus/env"

# claude with permissions skipped (danger zone)
alias kennyloggins="claude --dangerously-skip-permissions"

# google-cloud-sdk
[ -f "$HOME/projects/google-cloud-sdk/path.zsh.inc" ] && . "$HOME/projects/google-cloud-sdk/path.zsh.inc"
[ -f "$HOME/projects/google-cloud-sdk/completion.zsh.inc" ] && . "$HOME/projects/google-cloud-sdk/completion.zsh.inc"
