# ~/.nanorc — managed by myplace (chezmoi). Edit home/dot_nanorc.tmpl in the
# repo, not here; local edits show as drift.
#
# Turns on GNU nano syntax highlighting by including the syntax definitions that
# ship with the nano build, plus a few sensible defaults. NOTE: macOS
# /usr/bin/nano is pico and ignores this file entirely — real GNU nano comes
# from Homebrew (see .chezmoiscripts/run_onchange_provision.sh).

# --- syntax highlighting: include the bundled syntax definitions ---
{{- if eq .chezmoi.os "darwin" }}
include "{{ if eq .chezmoi.arch "arm64" }}/opt/homebrew{{ else }}/usr/local{{ end }}/share/nano/*.nanorc"
{{- else }}
include "/usr/share/nano/*.nanorc"
include "/usr/share/nano/extra/*.nanorc"
{{- end }}

# --- Catppuccin Mocha (mauve accent) for nano's interface chrome ---
# Matches ghostty/bat/starship/zed/atuin. nano only takes THREE-digit hex (#rgb)
# and approximates it from the terminal palette — so these are the nearest 3-digit
# stand-ins for the Mocha colors, not exact. Theme the UI only; syntax-highlight
# colors come from the bundled *.nanorc above (named colors the terminal already
# renders in Mocha), so they're not re-defined here. Attributes use commas (bold,fg).
# Mocha → #rgb: base #1e1e2e→#223  surface0 #313244→#334  surface1 #45475a→#445
#   overlay0 #6c7086→#678  text #cdd6f4→#cde  subtext0 #a6adc8→#aac
#   mauve #cba6f7→#caf  red #f38ba8→#e8a  yellow #f9e2af→#fda
set titlecolor    bold,#caf,#334   # title bar: mauve on surface0
set statuscolor   #223,#caf        # status feedback bar: base on mauve
set errorcolor    #223,#e8a        # error bar: base on red
set numbercolor   #678             # line-number gutter (when M-N toggles it on)
set keycolor      #caf             # ^X-style key combos: mauve
set functioncolor #aac             # their descriptions: subtext0
set promptcolor   #cde,#334        # answer prompts: text on surface0
set selectedcolor #cde,#445        # marked/selected text: text on surface1
set spotlightcolor #223,#fda       # search-match highlight: base on yellow
set scrollercolor #caf             # scrollbar thumb: mauve
set minicolor     #cde,#334        # minibar (when title bar hidden)

# --- editor niceties ---
# linenumbers off by default: the margin gutter is part of the terminal's
# selectable region, so a mouse drag grabs the numbers along with the text.
# Toggle them on live with M-N (Esc N / Alt+N) when you actually want them.
set constantshow     # always show the cursor's line/column
set tabsize 4
set autoindent       # keep the current indentation on a new line
set softwrap         # wrap long lines on screen instead of scrolling sideways
