#!/usr/bin/env bash
# portwhat — show what process is listening on each of the given TCP ports.
# mv_scripts: show what process is listening on a list of TCP ports
#
# Managed by myplace (chezmoi) — edit at home/dot_mvscripts/executable_portwhat
# in the repo, not at ~/.mvscripts/portwhat. See docs/adrs/0014.

set -euo pipefail

tab=$'\t'

show_help() {
  local r=cat
  if command -v gum >/dev/null 2>&1 && [ -t 1 ]; then r="gum format"; fi
  $r <<'EOF'
# portwhat

Report what (if anything) is listening on each TCP port you name. Read-only —
it never kills anything. To free a port, see `killport`.

With **no ports given**, lists everything currently listening on TCP in a table.

Ports are taken from all arguments, split on commas and/or whitespace, so any
of these work:

    portwhat                   list every listening TCP port (table)
    portwhat 3000
    portwhat 3000 8080 5432
    portwhat 3000,8080,5432
    portwhat "3000, 8080 5432"

Uses `lsof` when available, falling back to `fuser` (Linux) for named ports and
`ss` (Linux) for the listen-everything table.

## Usage

    portwhat                   list every listening TCP port as a table
    portwhat --json            same, machine-readable JSON array
    portwhat <ports...>        show listeners for each named port
    portwhat <ports...> --json machine-readable JSON array
    portwhat -h | --help       this help

## Exit codes

    0   listen-all succeeded, or every named port had a listener
    1   at least one named port was free
    2   usage error
    4   no port-inspection tool (lsof/fuser/ss) available
EOF
}

json=false
raw_args=()

while [ $# -gt 0 ]; do
  case "$1" in
    --json)    json=true ;;
    -h|--help) show_help; exit 0 ;;
    -*) echo "portwhat: unknown argument: $1" >&2; echo "try: portwhat --help" >&2; exit 2 ;;
    *)  raw_args+=("$1") ;;
  esac
  shift
done

# Emit one TSV row "port<TAB>pid<TAB>command<TAB>address" per TCP listener,
# using lsof when present and falling back to ss (Linux). fuser can't enumerate.
collect_all() {
  if command -v lsof >/dev/null 2>&1; then
    lsof +c 0 -nP -iTCP -sTCP:LISTEN -Fpcn 2>/dev/null | awk '
      /^p/ { pid = substr($0, 2); next }
      /^c/ { cmd = substr($0, 2); next }
      /^n/ {
        name = substr($0, 2)
        n = split(name, a, ":"); port = a[n]
        addr = substr(name, 1, length(name) - length(port) - 1)
        if (addr == "") addr = "*"
        print port "\t" pid "\t" cmd "\t" addr
      }'
  elif command -v ss >/dev/null 2>&1; then
    ss -tlnHp 2>/dev/null | awk '
      {
        laddr = $4
        n = split(laddr, a, ":"); port = a[n]
        addr = substr(laddr, 1, length(laddr) - length(port) - 1)
        if (addr == "") addr = "*"
        cmd = "?"; pid = "?"
        if (match($0, /\("[^"]+",pid=[0-9]+/)) {
          seg = substr($0, RSTART, RLENGTH)
          split(seg, b, "\"")
          cmd = b[2]
          match(seg, /pid=[0-9]+/); pid = substr(seg, RSTART + 4, RLENGTH - 4)
        }
        print port "\t" pid "\t" cmd "\t" addr
      }'
  fi
}

# ---- listen-everything mode (no ports given) ----------------------------------
if [ "${#raw_args[@]}" -eq 0 ]; then
  if ! command -v lsof >/dev/null 2>&1 && ! command -v ss >/dev/null 2>&1; then
    echo "portwhat: need lsof or ss to list all listening ports." >&2
    exit 4
  fi

  rows=$(collect_all | sort -u | sort -t"$tab" -k1,1n)

  if $json; then
    if [ -z "$rows" ]; then printf '[]\n'; exit 0; fi
    printf '%s\n' "$rows" | awk -F'\t' '
      function esc(s) { gsub(/\\/, "\\\\", s); gsub(/"/, "\\\"", s); return s }
      BEGIN { printf "["; firstport = 1 }
      {
        port = $1; pid = $2; cmd = $3
        if (port != cur) {
          if (!firstport) printf "]},"
          printf "\n  {\"port\":%s,\"listeners\":[", port
          cur = port; firstport = 0; firstpid = 1; delete seen
        }
        if (pid in seen) next
        seen[pid] = 1
        if (!firstpid) printf ","
        firstpid = 0
        pidout = (pid ~ /^[0-9]+$/) ? pid : "null"
        printf "{\"pid\":%s,\"command\":\"%s\"}", pidout, esc(cmd)
      }
      END { if (!firstport) printf "]}"; printf "\n]\n" }'
    exit 0
  fi

  if [ -z "$rows" ]; then
    echo "portwhat: nothing is listening on any TCP port." >&2
    exit 0
  fi

  printf '%s\n' "$rows" | awk -F'\t' '
    { r[NR] = $0; for (i = 1; i <= NF; i++) if (length($i) > w[i]) w[i] = length($i) }
    END {
      h[1] = "PORT"; h[2] = "PID"; h[3] = "COMMAND"; h[4] = "ADDRESS"
      for (i = 1; i <= 4; i++) if (length(h[i]) > w[i]) w[i] = length(h[i])
      printf "%-*s  %-*s  %-*s  %-*s\n", w[1], h[1], w[2], h[2], w[3], h[3], w[4], h[4]
      for (j = 1; j <= NR; j++) {
        split(r[j], f, "\t")
        printf "%-*s  %-*s  %-*s  %-*s\n", w[1], f[1], w[2], f[2], w[3], f[3], w[4], f[4]
      }
    }'
  exit 0
fi

# ---- named-port mode ----------------------------------------------------------
# Split every argument on commas/whitespace into a flat, de-duplicated port list,
# preserving first-seen order.
ports=()
seen=" "
for a in "${raw_args[@]}"; do
  for tok in ${a//,/ }; do
    if ! printf '%s' "$tok" | grep -qE '^[0-9]+$'; then
      echo "portwhat: not a numeric port: $tok" >&2
      exit 2
    fi
    case "$seen" in *" $tok "*) ;; *) ports+=("$tok"); seen+="$tok " ;; esac
  done
done

# Pick the inspection tool once up front.
tool=""
if command -v lsof >/dev/null 2>&1; then tool=lsof
elif command -v fuser >/dev/null 2>&1; then tool=fuser
else
  echo "portwhat: need lsof or fuser to inspect ports." >&2
  exit 4
fi

# Echo the listening pids for a port (one per line), or nothing.
pids_for() {
  local port="$1"
  if [ "$tool" = lsof ]; then
    lsof -nP -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null | sort -u || true
  else
    fuser "${port}/tcp" 2>/dev/null | tr -s ' ' '\n' | grep -E '^[0-9]+$' | sort -u || true
  fi
}

any_free=false

if $json; then
  printf '['
  first_port=true
  for port in "${ports[@]}"; do
    pids=$(pids_for "$port")
    [ -n "$pids" ] || any_free=true
    $first_port || printf ','
    first_port=false
    printf '\n  {"port":%s,"listeners":[' "$port"
    first_pid=true
    for p in $pids; do
      cmd=$(ps -p "$p" -o comm= 2>/dev/null || echo "")
      cmd=${cmd//\\/\\\\}; cmd=${cmd//\"/\\\"}
      $first_pid || printf ','
      first_pid=false
      printf '{"pid":%s,"command":"%s"}' "$p" "$cmd"
    done
    printf ']}'
  done
  printf '\n]\n'
  $any_free && exit 1
  exit 0
fi

for port in "${ports[@]}"; do
  pids=$(pids_for "$port")
  if [ -z "$pids" ]; then
    printf ':%s — free\n' "$port"
    any_free=true
    continue
  fi
  printf ':%s —\n' "$port"
  for p in $pids; do
    cmd=$(ps -p "$p" -o comm= 2>/dev/null || echo "?")
    printf '  pid %-8s %s\n' "$p" "$cmd"
  done
done

$any_free && exit 1
exit 0
