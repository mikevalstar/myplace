# Global tool set for every myplace-managed machine.
# Managed by chezmoi from the myplace repo — edit there, not here.
#
# Note: Rust is installed via rustup and Node via fnm (see ADR-0007 and
# home/.chezmoiscripts/run_onchange_provision.sh), so neither is managed here.

[tools]
# CLI baseline — installed on every machine, servers included.
jq = "latest"
ripgrep = "latest"
fd = "latest"
bat = "latest"
fzf = "latest"
eza = "latest"
zoxide = "latest"
starship = "latest"
atuin = "latest"
gum = "latest"
glow = "latest"
pnpm = "latest"
gh = "latest"
delta = "latest"
herdr = "latest"
lazygit = "latest"
fastfetch = "latest"
d2 = "latest"
git-lfs = "latest"
# Note: tokei is NOT here. It stopped shipping prebuilt binaries after v12, so
# mise's only backend for it is `cargo:` (source build) — and mise must not drive
# cargo (Rust is rustup's, ADR-0007). It's installed via rustup's cargo in
# run_onchange_provision.sh instead.
# bun: JS/TS runtime used as a runner for some managed scripts (ADR-0014).
# This is bun, not Node — Node stays with fnm (ADR-0007).
bun = "latest"
{{ if eq .chezmoi.os "linux" -}}
# btop's only mise backend (aqua) ships linux binaries only; macOS gets it via
# brew in run_onchange_provision.sh (ADR-0008).
btop = "latest"
{{ end -}}

[settings]
experimental = false
